# UBAI CST XRDP Runner example configuration.
# Copy this file to config/session.env and edit.

# ---------------------------------------------------------------------
# Enroot image
# ---------------------------------------------------------------------
export UBAI_BASE_IMAGE="docker://rockylinux/rockylinux:9.4"
export UBAI_IMAGE="$HOME/runtime/enroot/ubai-cst-rocky94-xrdp.sqsh"
export UBAI_ENROOT_NAME="ubai-cst-rocky94-xrdp"
export UBAI_BUILD_WORKDIR="$HOME/runtime/enroot/build-ubai-cst-rocky94"
export UBAI_PODMAN_IMAGE="localhost/ubai-cst-rocky94-xrdp:latest"
export UBAI_PODMAN_IMAGE_ARCHIVE="$HOME/runtime/podman/ubai-cst-rocky94-xrdp.tar"
export UBAI_PODMAN_RUNTIME="runc"
export UBAI_CONTAINERS_POLICY_JSON="$HOME/ubai_gui/config/containers-policy.json"
export UBAI_ROCKY_MIRROR="https://ftp.kaist.ac.kr/pub/rocky/9"
export UBAI_EPEL_MIRROR="https://ftp.kaist.ac.kr/pub/epel/9"

# ---------------------------------------------------------------------
# XRDP session inside container
# ---------------------------------------------------------------------
export UBAI_XRDP_PASSWORD="1q2w3e"
export UBAI_XRDP_PORT_IN_CONTAINER="3389"
export UBAI_CONTAINER_SSH_PORT="9922"
export UBAI_CONTAINER_SSH_PUBLIC_KEY=""
export UBAI_DESKTOP_GEOMETRY="1920x1080"
export UBAI_DESKTOP_DEPTH="24"
export UBAI_CONTAINER_ROOT_HOME="$HOME/runtime/container-root-home"

# ---------------------------------------------------------------------
# Gate relay SSH tunnel
# The compute node opens reverse ports on the gate node:
# ssh -R 127.0.0.1:${UBAI_REVERSE_LOCAL_PORT_ON_WINDOWS}:127.0.0.1:${UBAI_XRDP_PORT_IN_CONTAINER}
# ssh -R 127.0.0.1:${UBAI_REVERSE_LOCAL_SSH_PORT_ON_WINDOWS}:127.0.0.1:${UBAI_CONTAINER_SSH_PORT}
# The Windows GUI opens local forwards from this PC to the same gate ports.
# ---------------------------------------------------------------------
export UBAI_REVERSE_SSH_TARGET="UBAI_USER@172.16.10.36"
export UBAI_REVERSE_SSH_PORT="22"
export UBAI_REVERSE_LOCAL_PORT_ON_WINDOWS="9999"
export UBAI_REVERSE_LOCAL_SSH_PORT_ON_WINDOWS="9922"
export UBAI_REVERSE_BIND_HOST="127.0.0.1"
export UBAI_SSH_STRICT_HOST_KEY_CHECKING="accept-new"
export UBAI_SSH_IDENTITY_FILE=""

# ---------------------------------------------------------------------
# Slurm resources
# These are used by scripts/submit_xrdp_job.sh as sbatch arguments.
# ---------------------------------------------------------------------
export UBAI_SLURM_PARTITION=""
export UBAI_SLURM_TIME="04:00:00"
export UBAI_SLURM_CPUS_PER_TASK="4"
export UBAI_SLURM_MEM="16G"
export UBAI_SLURM_GPUS=""
export UBAI_CONTAINER_BACKEND="enroot"
export UBAI_IMAGE_BACKEND="enroot"

# ---------------------------------------------------------------------
# CST placeholders
# Fill these after xrdp desktop itself works.
# ---------------------------------------------------------------------
export UBAI_CST_INSTALLER_PATH=""
export UBAI_CST_INSTALL_DIR="/opt/cst"
export UBAI_CST_LICENSE_SERVER=""
export LM_LICENSE_FILE=""

# ---------------------------------------------------------------------
# Extra enroot mounts
# Comma separated host:container pairs.
# Example:
# export UBAI_EXTRA_MOUNTS="/scratch/$USER:/scratch,/data/shared:/data"
# ---------------------------------------------------------------------
export UBAI_EXTRA_MOUNTS=""

# ---------------------------------------------------------------------
# Debug
# ---------------------------------------------------------------------
export UBAI_KEEP_CONTAINER_AFTER_EXIT="0"
export UBAI_VERBOSE="1"
