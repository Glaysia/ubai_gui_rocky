# UABI CST XRDP Runner example configuration.
# Copy this file to config/session.env and edit.

# ---------------------------------------------------------------------
# Enroot image
# ---------------------------------------------------------------------
export UABI_BASE_IMAGE="docker://rockylinux:9.4"
export UABI_IMAGE="$HOME/runtime/enroot/uabi-cst-rocky94-xrdp.sqsh"
export UABI_ENROOT_NAME="uabi-cst-rocky94-xrdp"
export UABI_BUILD_WORKDIR="$HOME/runtime/enroot/build-uabi-cst-rocky94"
export UABI_PODMAN_IMAGE="localhost/uabi-cst-rocky94-xrdp:latest"
export UABI_PODMAN_IMAGE_ARCHIVE="$HOME/runtime/podman/uabi-cst-rocky94-xrdp.tar"
export UABI_PODMAN_RUNTIME="runc"
export UABI_CONTAINERS_POLICY_JSON="$HOME/ubai_gui/config/containers-policy.json"

# ---------------------------------------------------------------------
# XRDP session inside container
# ---------------------------------------------------------------------
export UABI_XRDP_USER="user"
export UABI_XRDP_PASSWORD="1q2w3e"
export UABI_XRDP_PORT_IN_CONTAINER="3389"
export UABI_DESKTOP_GEOMETRY="1920x1080"
export UABI_DESKTOP_DEPTH="24"

# ---------------------------------------------------------------------
# Reverse SSH tunnel
# UABI compute node will run:
# ssh -R 127.0.0.1:${UABI_REVERSE_LOCAL_PORT_ON_WINDOWS}:127.0.0.1:${UABI_XRDP_PORT_IN_CONTAINER}
# ---------------------------------------------------------------------
export UABI_REVERSE_SSH_TARGET="WINDOWS_USER@WINDOWS_HOST_OR_IP"
export UABI_REVERSE_SSH_PORT="10022"
export UABI_REVERSE_LOCAL_PORT_ON_WINDOWS="9999"
export UABI_REVERSE_BIND_HOST="127.0.0.1"
export UABI_SSH_STRICT_HOST_KEY_CHECKING="accept-new"
export UABI_SSH_IDENTITY_FILE=""

# ---------------------------------------------------------------------
# Slurm resources
# These are used by scripts/submit_xrdp_job.sh as sbatch arguments.
# ---------------------------------------------------------------------
export UABI_SLURM_PARTITION=""
export UABI_SLURM_TIME="04:00:00"
export UABI_SLURM_CPUS_PER_TASK="4"
export UABI_SLURM_MEM="16G"
export UABI_SLURM_GPUS=""

# ---------------------------------------------------------------------
# CST placeholders
# Fill these after xrdp desktop itself works.
# ---------------------------------------------------------------------
export UABI_CST_INSTALLER_PATH=""
export UABI_CST_INSTALL_DIR="/opt/cst"
export UABI_CST_LICENSE_SERVER=""
export LM_LICENSE_FILE=""

# ---------------------------------------------------------------------
# Extra enroot mounts
# Comma separated host:container pairs.
# Example:
# export UABI_EXTRA_MOUNTS="/scratch/$USER:/scratch,/data/shared:/data"
# ---------------------------------------------------------------------
export UABI_EXTRA_MOUNTS=""

# ---------------------------------------------------------------------
# Debug
# ---------------------------------------------------------------------
export UABI_KEEP_CONTAINER_AFTER_EXIT="0"
export UABI_VERBOSE="1"
